# Копируй в Railway → Variables

# PostgreSQL (Railway сам подставит если добавишь Postgres плагин)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Секретный ключ для хеширования паролей — поменяй на рандомную строку!
SECRET_KEY=your_super_secret_key_here_change_me

# Ключ для запросов от лоудера
ADMIN_KEY=glitchdlc_admin_secret_change_me

# Owner аккаунт (создаётся автоматически при первом запуске)
OWNER_USERNAME=admin
OWNER_PASSWORD=changeme123
OWNER_EMAIL=admin@glitchdlc.ru
